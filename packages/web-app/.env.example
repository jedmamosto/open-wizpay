# Public Client-side Firebase Configuration
# Replace these values with your Firebase Project configurations
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# Private Server-side Firebase Admin SDK Credentials
# Go to Firebase console -> Project Settings -> Service Accounts -> Generate new private key
NEXT_PRIVATE_FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
NEXT_PRIVATE_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBgkqhkiG9w0BAQEFAASCBKYwggSiAgEAAoIBAQCgn...\n-----END PRIVATE KEY-----\n"

# Core App settings
# Set to http://localhost:3000 for local development, or your custom domain in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin Dashboard Credentials (for self-hosted single-tenant access)
ADMIN_EMAIL=admin@wizpay.local
ADMIN_PASSWORD=admin-secure-password
SESSION_SECRET=a_very_long_secure_random_string_for_signing_sessions

# Developer Sandbox API key
# Used as a fallback key for local MCP integrations and testing without database authentication.
# Maps to user ID "test-user-mcp". Must start with "wzp_live_" or matching pattern.
WIZPAY_DEV_API_KEY=wzp_sandbox_development_api_key_12345

