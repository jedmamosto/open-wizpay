datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model PaymentForm {
  id                      String   @id @default(uuid())
  paymentFormTitle        String
  paymentFormDescription  String
  paymentFormSuccessURL   String
  paymentFormCancelURL    String
  paymentFormWebhookURL   String   @default("")
  paymentFormProducts     String   // Serialized JSON Array of Products
  appearance              String   // Serialized JSON of FormAppearance
  userId                  String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model CheckoutSession {
  id                String   @id // PayMongo Checkout Session / Payment Intent ID
  paymentFormId     String
  customerName      String
  customerEmail     String
  customerPhone     String
  selectedProducts  String   // Serialized JSON Array of selected items
  status            String   // pending | paid | failed
  paymentToken      String   @unique
  shippingAddress   String?  // Serialized JSON of ShippingAddress
  createdAt         DateTime @default(now())
  paidAt            DateTime?
}
