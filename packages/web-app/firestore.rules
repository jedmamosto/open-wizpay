rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read and write their own profile document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Signups cannot be read or written directly by client-side Web SDK
    match /signups/{signUpId} {
      allow read, write: if false;
    }
    
    // Payment forms are only accessed via Next.js API Routes (Admin SDK)
    match /payment-forms/{paymentFormId} {
      allow read, write: if false;
    }

    // Checkout sessions are only accessed via Next.js API Routes (Admin SDK)
    match /checkout-sessions/{sessionId} {
      allow read, write: if false;
    }

    // API Keys must NEVER be read or written to directly by clients
    match /api-keys/{keyId} {
      allow read, write: if false;
    }
  }
}