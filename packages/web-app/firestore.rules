rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read and write their own profile document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Signups can only be created by anyone, but not read publicly
    match /signups/{signUpId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    
    // Payment forms are read-only for public checkout sessions, 
    // and can only be written/edited by their owner
    match /payment-forms/{paymentFormId} {
      allow read: if true;
      allow write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Checkout sessions can only be created client-side, not modified or read directly
    match /checkout-sessions/{sessionId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // API Keys must NEVER be read or written to directly by clients
    match /api-keys/{keyId} {
      allow read, write: if false;
    }
  }
}